{
  "name": "feminista",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "dotnet tool restore",
    "dev": "dotnet fable watch --noRestore --run npx vite",
    "build": "dotnet fable --noRestore --configuration Release && vite build",
    "update:latest-facts": "node scripts/update-latest-facts.mjs",
    "preview": "vite preview",
    "start": "node server.mjs",
    "start:local": "dotnet fable --noRestore --configuration Debug && node --env-file=.env.local server.mjs",
    "prod": "npm run start"
  },
  "dependencies": {
    "@fable-org/fable-library-js": "^1.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^7.0.0"
  }
}
